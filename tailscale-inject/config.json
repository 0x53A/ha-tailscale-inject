{
  "name": "Tailscale Inject",
  "description": "Expose LAN devices as individual Tailscale nodes with per-device ACLs",
  "slug": "tailscale-inject",
  "version": "0.6.0",
  "url": "https://github.com/0x53A/ha-tailscale-inject",
  "arch": ["aarch64", "amd64"],
  "startup": "services",
  "boot": "auto",
  "init": false,
  "docker_api": true,
  "full_access": true,
  "host_network": true,
  "map": ["config:rw", "share:rw", "ssl:ro"],
  "options": {
    "auth_key": "",
    "devices": []
  },
  "schema": {
    "auth_key": "str?",
    "devices": [
      {
        "name": "str",
        "target": "str",
        "auth_key": "str?",
        "ports": ["str"]
      }
    ]
  }
}
